# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running the dev server
# or building for production.
# NEVER commit the real .env file to version control.
# All variables exposed to the browser MUST be prefixed with VITE_.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used by src/lib/api.js, Login.jsx, VerifyEmail.jsx, ResetPassword.jsx)
# In development the Vite proxy forwards /api → http://localhost:8000 so this
# can stay as-is. In production (Vercel), set to your Hugging Face Space URL:
#   VITE_API_BASE=https://your-username-your-space-name.hf.space/api
VITE_API_BASE=http://localhost:8000/api

# Google OAuth Client ID (from Google Cloud Console → Credentials)
# Must match the GOOGLE_CLIENT_ID set in the backend .env
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
